# =============================================================================
# FlashAudit Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker-compose up.
#
# Required variables are marked with (REQUIRED).
# All others have sensible defaults.
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets (REQUIRED)
# ---------------------------------------------------------------------------

# Admin key for creating organizations via POST /api/v1/admin/organizations
# Must be at least 16 characters. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_KEY=

# PostgreSQL password. Generate a strong one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# PostgreSQL connection string (docker-compose sets this automatically)
# DATABASE_URL=postgresql+asyncpg://flashaudit:${POSTGRES_PASSWORD}@postgres:5432/flashaudit

# Query logging (set to true to see SQL in logs — never in production)
# SQL_ECHO=false

# Connection pool settings (PostgreSQL only)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=1800

# ---------------------------------------------------------------------------
# Backend Server
# ---------------------------------------------------------------------------

# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=INFO
# RELOAD=false

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------

# CORS allowed origins (comma-separated). Default: http://localhost:3000
# WARNING: Never use * in production with allow_credentials=True
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Session cookie Secure flag. Must be true for HTTPS deployments.
# Set to false only for local HTTP development.
# COOKIE_SECURE=true

# Session lifetime in hours
# SESSION_TTL_HOURS=24

# Login rate limiting (per IP)
# LOGIN_RATE_LIMIT_MAX=5

# CLI rate limiting (per organization)
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# API Documentation
# ---------------------------------------------------------------------------

# Enable /docs and /redoc endpoints
# ENABLE_DOCS=true

# Enable admin endpoints in documentation (hidden by default)
# ENABLE_ADMIN_DOCS=false

# ---------------------------------------------------------------------------
# Dashboard
# ---------------------------------------------------------------------------

# Backend API URL for the Next.js dashboard
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional Services
# ---------------------------------------------------------------------------

# Redis URL for distributed rate limiting (empty = in-memory fallback)
# REDIS_URL=redis://redis:6379/0
